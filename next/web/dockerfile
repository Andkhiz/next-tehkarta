# Шаг 1: Установка зависимостей (остается без изменений)
FROM node:20-alpine AS deps
WORKDIR /app
COPY package*.json ./
RUN npm ci

# Шаг 2: Сборка приложения
FROM node:20-alpine AS builder
WORKDIR /app
COPY --from=deps /app/node_modules ./node_modules
COPY . .

# --- ДОБАВЬТЕ ЭТУ СТРОЧКУ ---
# Генерируем клиент Prisma внутри Linux-окружения Docker перед сборкой Next.js
RUN npx prisma generate

# Отключаем телеметрию и компилируем production-билд
ENV NEXT_TELEMETRY_DISABLED=1
RUN npm run build

# Шаг 3: Запуск готового production-сервера (остается без изменений)
FROM node:20-alpine AS runner
WORKDIR /app
ENV NODE_ENV=production
COPY --from=builder /app/.next ./.next
COPY --from=builder /app/node_modules ./node_modules
COPY --from=builder /app/package.json ./package.json
COPY --from=builder /app/public ./public
COPY --from=builder /app/prisma ./prisma

EXPOSE 3000
CMD ["npm", "run", "start"]

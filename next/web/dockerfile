# === Шаг 1: Установка ВСЕХ зависимостей ===
FROM node:20-alpine AS deps
RUN apk add --no-cache libc6-compat
WORKDIR /app
COPY package*.json ./
COPY prisma ./prisma/
RUN npm ci

# === Шаг 2: Сборка приложения ===
FROM node:20-alpine AS builder
WORKDIR /app
COPY --from=deps /app/node_modules ./node_modules
COPY . .

RUN npx prisma generate
ENV NEXT_TELEMETRY_DISABLED=1
RUN npm run build

# === Шаг 3: Финальный минимальный образ ===
FROM node:20-alpine AS runner
WORKDIR /app

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1

RUN apk add --no-cache netcat-openbsd

RUN addgroup --system --gid 1001 nodejs
RUN adduser --system --uid 1001 nextjs

# Копируем только статику и публичные файлы
COPY --from=builder /app/public ./public

# Магия standalone: копируем только собранный минимальный сервер и зависимости
COPY --from=builder --chown=nextjs:nodejs /app/.next/standalone ./
COPY --from=builder --chown=nextjs:nodejs /app/.next/static ./.next/static

# Для работы скрипта нам всё ещё нужна схема Prisma
COPY --from=builder /app/prisma ./prisma

# Копируем скрипт запуска
COPY entrypoint.sh ./
RUN sed -i 's/\r$//' entrypoint.sh
RUN chmod +x entrypoint.sh

USER nextjs
EXPOSE 3000
ENV PORT=3000

ENTRYPOINT ["./entrypoint.sh"]

// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

// Шапка технологической карты (ГОСТ 3.1118-82)
model RouteCard {
  id              Int         @id @default(autoincrement())
  documentNumber  String      @unique @map("document_number")
  partName        String      @map("part_name")       
  material        String      
  massKg          Float       @map("mass_kg")    
  massZagKg       Float       @default(0) @map("mass_zag_kg")      
  profileSize     String      @map("profile_size")    
  operations      Operation[] 
  createdAt       DateTime    @default(now()) @map("created_at")

  @@map("route_cards")
}

// Операции процесса
model Operation {
  id              Int            @id @default(autoincrement())
  routeCardId     Int            @map("route_card_id")
  routeCard       RouteCard      @relation(fields: [routeCardId], references: [id], onDelete: Cascade)
  
  operationNumber String         @map("operation_number") 
  operationName   String         @map("operation_name")   
  workplace       String?        @map("workplace")        
  equipment       String?        @map("equipment")        
  
  nv              Float?         @map("time_standard")
  rows            OperationRow[] // Операция содержит только массив строк переходов
  order           Int            

  @@map("operations")
}

// Справочник: Режущий инструмент
model CuttingToolCatalog {
  id          Int               @id @default(autoincrement())
  name        String            @unique 
  description String?
  rowTools    RowCuttingTool[]  // Связь переведена на строки

  @@map("cutting_tool_catalog")
}

// Справочник: Мерительный инструмент
model MeasuringToolCatalog {
  id          Int                @id @default(autoincrement())
  name        String             @unique
  description String?
  rowTools    RowMeasuringTool[] // Связь переведена на строки

  @@map("measuring_tool_catalog")
}

// Строки внутри операции (Переходы, оснастка)
model OperationRow {
  id             Int                @id @default(autoincrement())
  operationId    Int                @map("operation_id")
  operation      Operation          @relation(fields: [operationId], references: [id], onDelete: Cascade)
  
  rowType        String             @map("row_type") 
  text           String    
  order          Int       

  // ИНСТРУМЕНТЫ ТЕПЕРЬ ПРИВЯЗАНЫ НАПРЯМУЮ К СТРОКЕ ПЕРЕХОДА
  cuttingTools   RowCuttingTool[]   
  measuringTools RowMeasuringTool[] 

  @@map("operation_rows")
}

// Новая промежуточная таблица: Строки переходов <-> Режущие инструменты
model RowCuttingTool {
  id            Int                @id @default(autoincrement()) // Суррогатный ID убирает ограничение уникальности
  rowId         Int                @map("row_id")
  cuttingToolId Int                @map("cutting_tool_id")
  
  row           OperationRow       @relation(fields: [rowId], references: [id], onDelete: Cascade)
  cuttingTool   CuttingToolCatalog @relation(fields: [cuttingToolId], references: [id], onDelete: Cascade)

  @@map("row_cutting_tools")
}

// Новая промежуточная таблица: Строки переходов <-> Мерительные инструменты
model RowMeasuringTool {
  id              Int                  @id @default(autoincrement()) // Суррогатный ID убирает ограничение уникальности
  rowId           Int                  @map("row_id")
  measuringToolId Int                  @map("measuring_tool_id")
  
  row             OperationRow         @relation(fields: [rowId], references: [id], onDelete: Cascade)
  measuringTool   MeasuringToolCatalog @relation(fields: [measuringToolId], references: [id], onDelete: Cascade)

  @@map("row_measuring_tools")
}
